{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/felmonon/agent-reliability-harness/blob/main/schemas/report.schema.json",
  "title": "ARH Validation Report",
  "description": "Output of 'arh validate --json-out'; also the regression baseline format consumed by 'arh compare'.",
  "type": "object",
  "required": ["summary", "reports"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1(\\..*)?$" },
    "summary": {
      "type": "object",
      "required": ["total_traces", "passed_traces", "failed_traces", "average_score"],
      "properties": {
        "total_traces": { "type": "integer", "minimum": 0 },
        "passed_traces": { "type": "integer", "minimum": 0 },
        "failed_traces": { "type": "integer", "minimum": 0 },
        "average_score": { "type": "number" }
      }
    },
    "reports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["trace_id", "policy_id", "score", "passed", "findings"],
        "properties": {
          "trace_id": { "type": "string" },
          "agent_name": { "type": "string" },
          "workflow": { "type": "string" },
          "policy_id": { "type": "string" },
          "score": { "type": "number", "minimum": 0, "maximum": 100 },
          "passed": { "type": "boolean" },
          "total_latency_ms": { "type": "number" },
          "total_cost_usd": { "type": "number" },
          "total_tokens": { "type": ["integer", "null"] },
          "citation_coverage": { "type": ["number", "null"] },
          "source_path": { "type": "string" },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["severity", "category", "message"],
              "properties": {
                "severity": { "enum": ["error", "warning", "info"] },
                "category": { "type": "string" },
                "message": { "type": "string" },
                "step_id": { "type": ["string", "null"] },
                "rule_id": { "type": "string" },
                "expected": { "type": "string" },
                "observed": { "type": "string" },
                "remediation": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
